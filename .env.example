# Copy to .env and fill in values before running integration tests.
# Never commit .env to version control.

# Funded Stellar testnet keypair (get free XLM at https://laboratory.stellar.org/#account-creator)
STELLAR_SECRET_KEY=

# Deployed contract addresses on testnet
IDENTITY_REGISTRY=
PAYMENT_ROUTER=

# Paths to compiled circuit artifacts (produced by `circom` + `snarkjs`)
PAYMENT_PROOF_WASM=circuits/payment_proof_js/payment_proof.wasm
PAYMENT_PROOF_ZKEY=circuits/payment_proof_0001.zkey
